<script>
let ESP = null; // dados do especialista logado
let _leads=[], _negs=[], _projs=[];
let projAtual=null, leadAtualNeg=null;

// AUTH
async function fazerLogin(){
  const email=document.getElementById('loginEmail').value.trim();
  const senha=document.getElementById('loginSenha').value;
  if(!email||!senha)return;
  try{
    const r=await fetch('/api/login-prestador',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email,senha})});
    const d=await r.json();
    if(d.ok&&d.prestador){
      ESP=d.prestador;
      localStorage.setItem('esp',JSON.stringify(ESP));
      iniciarApp();
    } else {
      document.getElementById('loginErr').style.display='block';
    }
  }catch(e){document.getElementById('loginErr').style.display='block';}
}
function fazerLogout(){localStorage.removeItem('esp');location.reload();}
window.onload=()=>{
  const s=localStorage.getItem('esp');
  if(s){try{ESP=JSON.parse(s);iniciarApp();}catch{}}
  document.getElementById('loginSenha').addEventListener('keydown',e=>{if(e.key==='Enter')fazerLogin();});
};
function iniciarApp(){
  document.getElementById('loginScreen').style.display='none';
  document.getElementById('app').style.display='block';
  document.getElementById('topUser').textContent=ESP.nome||ESP.email;
  document.getElementById('welcomeMsg').textContent='Olá, '+( ESP.nome||'Especialista');
  loadDash();
  setInterval(loadDash,60000);
}

// HELPERS
const fM=v=>v?'R$ '+Number(v).toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2}):'R$ 0,00';
const fD=d=>d?new Date(d).toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit',year:'2-digit',hour:'2-digit',minute:'2-digit'}):'—';
function cm(id){document.getElementById(id).classList.remove('open');}
function notif(msg,bg='var(--accent)'){
  const n=document.getElementById('notif');
  n.textContent=msg;n.style.background=bg;n.style.display='block';
  setTimeout(()=>n.style.display='none',3500);
}
function showTab(t,el){
  document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));
  document.querySelectorAll('.page').forEach(x=>x.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('page-'+t).classList.add('active');
  const m={leads_atrib:loadLeads,negociacoes:loadNegs,projetos:loadProjs,financeiro:loadFin};
  if(m[t])m[t]();
}
function bNe(s){const m={aguardando_validacao:'by ⏳ Aguardando admin',aprovada:'bg ✅ Aprovada',revisao:'br 🔄 Revisar'};const c=m[s]||'bgr '+s;const[cl,...r]=c.split(' ');return`<span class="badge ${cl}">${r.join(' ')}</span>`;}
function bPj(s){const m={em_andamento:'bb 🔄 Em andamento',concluido:'bg ✅ Concluído',aguardando_cliente:'by ⏳ Aguardando cliente'};const c=m[s]||'bgr '+s;const[cl,...r]=c.split(' ');return`<span class="badge ${cl}">${r.join(' ')}</span>`;}
function bFi(s){const m={pendente:'by ⏳ Pendente',pago:'bg ✅ Pago',cancelado:'br ❌ Cancelado'};const c=m[s]||'bgr '+s;const[cl,...r]=c.split(' ');return`<span class="badge ${cl}">${r.join(' ')}</span>`;}

// DASHBOARD
async function loadDash(){
  if(!ESP)return;
  try{
    const[lR,nR,pR,fR]=await Promise.all([
      fetch(`/api/leads?especialista_id=${ESP.id}`).then(r=>r.json()),
      fetch(`/api/negociacoes?especialista_id=${ESP.id}`).then(r=>r.json()),
      fetch(`/api/projetos?especialista_id=${ESP.id}`).then(r=>r.json()),
      fetch(`/api/admin-financeiro?especialista_id=${ESP.id}`).then(r=>r.json()),
    ]);
    _leads=lR.leads||[];
    _negs=nR.negociacoes||[];
    _projs=pR.projetos||[];
    const fin=fR.totais||{};

    const revisoes=_negs.filter(n=>n.status==='revisao').length;
    const projAtivos=_projs.filter(p=>p.status==='em_andamento').length;
    const msgsPend=_projs.reduce((a,p)=>a+parseInt(p.mensagens_pendentes||0),0);

    document.getElementById('dLeads').textContent=_leads.length;
    document.getElementById('dNegs').textContent=_negs.length;
    document.getElementById('dProj').textContent=projAtivos;
    document.getElementById('dRec').textContent=fM(fin.total_liquido||0);
    document.getElementById('bLeads').textContent=_leads.filter(l=>l.status==='em_negociacao'||l.status==='novo').length;
    document.getElementById('bRevisoes').textContent=revisoes;
    document.getElementById('bMsgs').textContent=msgsPend;

    // Alertas
    let alertas='';
