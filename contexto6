    <div class="page" id="page-oportunidades">
      <div class="page-title">Oportunidades</div>
      <div class="page-sub">Pedidos dos clientes — analise e publique para os especialistas</div>
      <div class="filter-row">
        <button class="fb active" onclick="filtO('pendente',this)">⏳ Pendentes</button>
        <button class="fb" onclick="filtO('aberta',this)">✅ Abertas</button>
        <button class="fb" onclick="filtO('em_andamento',this)">🔄 Em andamento</button>
        <button class="fb" onclick="filtO('concluida',this)">🏁 Concluídas</button>
