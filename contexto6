    </div>

  </div>
</div>

<!-- Modal especialista -->
<div class="mo" id="moEsp">
  <div class="modal">
    <div class="modal-title">Detalhes do Especialista <button class="mc" onclick="cm('moEsp')">✕</button></div>
    <div id="moEspBody"></div>
    <div style="display:flex;gap:8px;margin-top:14px" id="moEspAct"></div>
  </div>
</div>

<!-- Modal ticket -->
<div class="mo" id="moTick">
  <div class="modal">
    <div class="modal-title"><span id="tickTitle">Ticket</span> <button class="mc" onclick="cm('moTick')">✕</button></div>
    <div class="thread" id="tickThread"></div>
    <div class="field"><label>Resposta</label><textarea id="tickResp" placeholder="Digite sua resposta..."></textarea></div>
    <div style="display:flex;gap:8px">
      <button class="btn btn-a" style="flex:1;padding:10px;border-radius:8px" onclick="respTick()">Enviar</button>
      <button class="btn btn-o" style="padding:10px 14px;border-radius:8px" onclick="fecharTick()">Fechar Ticket</button>
    </div>
  </div>
</div>

<!-- Modal reprovar -->
<div class="mo" id="moMotivo">
  <div class="modal">
    <div class="modal-title">Motivo da Reprovação <button class="mc" onclick="cm('moMotivo')">✕</button></div>
    <div class="field"><label>Motivo</label><textarea id="motivoTxt" placeholder="Explique o motivo..."></textarea></div>
    <div style="display:flex;gap:8px">
      <button class="btn btn-r" style="flex:1;padding:10px;border-radius:8px" onclick="confirmarRep()">Confirmar</button>
      <button class="btn btn-o" style="padding:10px 14px;border-radius:8px" onclick="cm('moMotivo')">Cancelar</button>
    </div>
  </div>
</div>

<script>
let tickAtual=null, repId=null, espList=[];

function adminLogin(){
  const e=document.getElementById('adminEmail').value.trim();
  const s=document.getElementById('adminSenha').value;
  if(e==='admin@123consultoria.com.br'&&s==='admin@123'){
    sessionStorage.setItem('adm','1');
    document.getElementById('loginScreen').style.display='none';
    document.getElementById('app').style.display='block';
    init();
  } else { document.getElementById('loginErr').style.display='block'; }
}
document.addEventListener('DOMContentLoaded',()=>{
  document.getElementById('adminSenha').addEventListener('keydown',e=>{if(e.key==='Enter')adminLogin();});
  if(sessionStorage.getItem('adm')){
    document.getElementById('loginScreen').style.display='none';
    document.getElementById('app').style.display='block';
    init();
  }
  setInterval(()=>{document.getElementById('clock').textContent=new Date().toLocaleTimeString('pt-BR');},1000);
});
function adminLogout(){sessionStorage.removeItem('adm');location.reload();}

function showTab(n){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('page-'+n).classList.add('active');
  document.querySelectorAll('.tab').forEach(t=>{if(t.getAttribute('onclick')?.includes("'"+n+"'"))t.classList.add('active');});
}
function notif(msg,cor='var(--green)'){
  const el=document.getElementById('notif');
  el.textContent=msg;el.style.background=cor;el.style.display='block';
  setTimeout(()=>el.style.display='none',3000);
}
function cm(id){document.getElementById(id).classList.remove('open');}
function pJ(v){try{return typeof v==='string'?JSON.parse(v):v||[];}catch{return[];}}
function fM(v){return'R$ '+Number(v||0).toLocaleString('pt-BR',{minimumFractionDigits:0});}
function fMF(v){return'R$ '+Number(v||0).toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2});}
function fD(d){if(!d)return'—';return new Date(d).toLocaleString('pt-BR',{day:'2-digit',month:'2-digit',year:'2-digit',hour:'2-digit',minute:'2-digit'});}
function esc(s){return(s||'').replace(/'/g,"\\'");}
function bSt(s){const m={ativo:['bg','✅ Ativo'],em_analise:['by','⏳ Em análise'],reprovado:['br','❌ Reprovado']};const[c,t]=m[s]||['bgr',s];return`<span class="badge ${c}">${t}</span>`;}
function bOp(s){const m={pendente:['by','⏳ Pendente'],aberta:['bb','✅ Aberta'],em_andamento:['bg','🔄 Em andamento'],concluida:['bgr','🏁 Concluída'],cancelada:['br','❌ Cancelada']};const[c,t]=m[s]||['bgr',s];return`<span class="badge ${c}">${t}</span>`;}
function bCa(s){const m={pendente:['by','⏳ Pendente'],aprovada:['bg','✅ Aprovada'],reprovada:['br','❌ Recusada']};const[c,t]=m[s]||['bgr',s];return`<span class="badge ${c}">${t}</span>`;}
function bFi(s){const m={pendente:['by','Pendente'],pago:['bg','✅ Pago'],cancelado:['br','Cancelado']};const[c,t]=m[s]||['bgr',s];return`<span class="badge ${c}">${t}</span>`;}
function bTi(s){const m={aberto:['br','🔴 Aberto'],respondido:['by','🟡 Respondido'],fechado:['bg','✅ Fechado']};const[c,t]=m[s]||['bgr',s];return`<span class="badge ${c}">${t}</span>`;}

async function init(){
  await Promise.all([loadDash(),loadEsp('em_analise'),loadOport('pendente'),loadCand(),loadFin(),loadTick('aberto')]);
}

// DASHBOARD
async function loadDash(){
  try{
    const [at,pe,op,ti,fi,ca]=await Promise.all([
      fetch('/api/admin-prestadores?status=ativo').then(r=>r.json()),
      fetch('/api/admin-prestadores?status=em_analise').then(r=>r.json()),
      fetch('/api/oportunidades?status=aberta').then(r=>r.json()),
      fetch('/api/tickets').then(r=>r.json()),
      fetch('/api/admin-financeiro').then(r=>r.json()),
      fetch('/api/candidaturas').then(r=>r.json()),
    ]);
    const ativos=at.prestadores?.length||0;
    const pend=pe.prestadores?.length||0;
    const oports=op.oportunidades?.length||0;
    const ticks=(ti.tickets||[]).filter(t=>t.status==='aberto').length;
    const cands=(ca.candidaturas||[]).filter(c=>c.status==='pendente').length;
    document.getElementById('dAtivos').textContent=ativos;
    document.getElementById('dPend').textContent=pend;
    document.getElementById('dOport').textContent=oports;
    document.getElementById('dCand').textContent=cands;
    document.getElementById('dTick').textContent=ticks;
    document.getElementById('dReceita').textContent=fM(fi.totais?.total_comissao||0);
    document.getElementById('bPend').textContent=pend;
    document.getElementById('bOport').textContent=oports;
    document.getElementById('bCand').textContent=cands;
    document.getElementById('bTick').textContent=ticks;
    // Auditoria
    const aud=await fetch('/api/auditoria').then(r=>r.json()).catch(()=>({logs:[]}));
    document.getElementById('dashAud').innerHTML=(aud.logs||[]).length===0
      ?'<div class="empty">Nenhuma ação ainda</div>'
      :(aud.logs||[]).slice(0,5).map(l=>`<div class="card" style="margin-bottom:7px"><div class="card-body" style="padding:10px 14px"><div style="font-size:.8rem;font-weight:500">${l.evento||'—'}</div><div style="font-size:.72rem;color:var(--muted)">${l.detalhes||''} · ${fD(l.created_at)}</div></div></div>`).join('');
    // Tickets urgentes
    const tabs=(ti.tickets||[]).filter(t=>t.status==='aberto').slice(0,3);
    document.getElementById('dashTick').innerHTML=tabs.length===0
      ?'<div class="empty">Nenhum ticket aberto 🎉</div>'
      :tabs.map(t=>`<div class="card" style="margin-bottom:7px;cursor:pointer" onclick="abrirTick(${t.id},'${esc(t.assunto)}')"><div class="card-body" style="padding:10px 14px"><div style="font-size:.8rem;font-weight:500">${t.assunto||'—'}</div><div style="font-size:.72rem;color:var(--muted)">${t.prestador_nome} · ${fD(t.created_at)}</div></div></div>`).join('');
  }catch(e){console.error(e);}
}

// ESPECIALISTAS
async function loadEsp(status='em_analise'){
  document.getElementById('listaEsp').innerHTML='<div class="loading">Carregando...</div>';
  try{
    const url=status?`/api/admin-prestadores?status=${status}`:'/api/admin-prestadores';
    const data=await fetch(url).then(r=>r.json());
    espList=data.prestadores||[];
    if(!espList.length){document.getElementById('listaEsp').innerHTML='<div class="empty">Nenhum especialista encontrado</div>';return;}
    document.getElementById('listaEsp').innerHTML=espList.map(p=>{
      const es=pJ(p.especialidades);
      return`<div class="card">
        <div class="card-header">
          <div><div class="card-title">${p.nome||'—'}</div><div class="card-sub">${p.email} · ${p.whatsapp||'—'}</div></div>
          ${bSt(p.status)}
        </div>
        <div class="card-body">
          <div style="display:flex;flex-wrap:wrap;gap:5px;margin-bottom:9px">${es.map(e=>`<span class="badge bb">${e}</span>`).join('')||'<span style="color:var(--muted);font-size:.78rem">Sem especialidades</span>'}</div>
          ${p.bio?`<div style="font-size:.78rem;color:var(--muted);margin-bottom:8px">${p.bio.substring(0,100)}${p.bio.length>100?'...':''}</div>`:''}
          <div class="info-row"><span>📅 ${fD(p.created_at)}</span></div>
          <div class="actions">
            <button class="btn btn-o" onclick="verEsp(${p.id})">👁 Detalhes</button>
            ${p.status==='em_analise'?`<button class="btn btn-g" onclick="aprovarP(${p.id})">✅ Aprovar</button><button class="btn btn-r" onclick="iniciarRep(${p.id})">❌ Reprovar</button>`:''}
            ${p.status==='ativo'?`<button class="btn btn-r" onclick="iniciarRep(${p.id})">🚫 Suspender</button>`:''}
            ${p.status==='reprovado'?`<button class="btn btn-g" onclick="aprovarP(${p.id})">↩ Reativar</button>`:''}
          </div>
        </div>
      </div>`;
    }).join('');
  }catch(e){document.getElementById('listaEsp').innerHTML='<div class="empty">Erro ao carregar</div>';}
}
function filtP(s,btn){document.querySelectorAll('#page-especialistas .fb').forEach(b=>b.classList.remove('active'));btn.classList.add('active');loadEsp(s);}
async function aprovarP(id){
  await fetch('/api/admin-prestadores',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({id,status:'ativo'})});
  notif('✅ Especialista aprovado!');loadEsp();loadDash();
}
function iniciarRep(id){repId=id;document.getElementById('moMotivo').classList.add('open');}
async function confirmarRep(){
  const motivo=document.getElementById('motivoTxt').value;
  await fetch('/api/admin-prestadores',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:repId,status:'reprovado',motivo})});
  cm('moMotivo');notif('Especialista reprovado','var(--red)');
  document.getElementById('motivoTxt').value='';loadEsp();loadDash();
}
function verEsp(id){
  const p=espList.find(x=>x.id===id);if(!p)return;
  const es=pJ(p.especialidades);
  document.getElementById('moEspBody').innerHTML=`
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px">
      <div><div style="font-size:.7rem;color:var(--muted);text-transform:uppercase;margin-bottom:2px">Nome</div>${p.nome||'—'}</div>
      <div><div style="font-size:.7rem;color:var(--muted);text-transform:uppercase;margin-bottom:2px">E-mail</div>${p.email||'—'}</div>
      <div><div style="font-size:.7rem;color:var(--muted);text-transform:uppercase;margin-bottom:2px">WhatsApp</div>${p.whatsapp||'—'}</div>
      <div><div style="font-size:.7rem;color:var(--muted);text-transform:uppercase;margin-bottom:2px">Status</div>${bSt(p.status)}</div>
    </div>
    <div style="margin-bottom:10px"><div style="font-size:.7rem;color:var(--muted);text-transform:uppercase;margin-bottom:5px">Especialidades</div><div style="display:flex;flex-wrap:wrap;gap:5px">${es.map(e=>`<span class="badge bb">${e}</span>`).join('')||'—'}</div></div>
    <div><div style="font-size:.7rem;color:var(--muted);text-transform:uppercase;margin-bottom:5px">Bio</div><div style="font-size:.82rem;color:var(--muted);line-height:1.5">${p.bio||'—'}</div></div>
    <div style="margin-top:10px"><div style="font-size:.7rem;color:var(--muted);text-transform:uppercase;margin-bottom:3px">Cadastro</div><div style="font-size:.78rem;color:var(--muted)">${fD(p.created_at)}</div></div>`;
  document.getElementById('moEspAct').innerHTML=p.status==='em_analise'
    ?`<button class="btn btn-g" style="flex:1;padding:10px;border-radius:8px" onclick="aprovarP(${p.id});cm('moEsp')">✅ Aprovar</button>
       <button class="btn btn-r" style="padding:10px 14px;border-radius:8px" onclick="cm('moEsp');iniciarRep(${p.id})">❌ Reprovar</button>`
    :`<button class="btn btn-o" style="padding:10px 16px;border-radius:8px" onclick="cm('moEsp')">Fechar</button>`;
  document.getElementById('moEsp').classList.add('open');
}

// OPORTUNIDADES
async function loadOport(status='pendente'){
  document.getElementById('listaOport').innerHTML='<div class="loading">Carregando...</div>';
  try{
    const data=await fetch(`/api/oportunidades?status=${status}`).then(r=>r.json());
    const lista=data.oportunidades||[];
    if(!lista.length){document.getElementById('listaOport').innerHTML='<div class="empty">Nenhuma oportunidade</div>';return;}
    document.getElementById('listaOport').innerHTML=lista.map(o=>`
      <div class="card">
        <div class="card-header">
          <div><div class="card-title">${o.titulo}</div><div class="card-sub">${o.empresa} · ${o.area||'—'}</div></div>
          <div style="text-align:right">${bOp(o.status)}<div style="font-size:1rem;font-weight:700;color:var(--green);margin-top:3px;font-family:'Cormorant Garamond',serif">${fM(o.valor)}</div></div>
        </div>
        <div class="card-body">
          <p style="font-size:.8rem;color:var(--muted);margin-bottom:10px">${o.descricao||'—'}</p>
          <div class="info-row"><span>📅 ${o.prazo||'—'}</span><span>📧 ${o.email_empresa||'—'}</span><span>👤 ${o.contato_empresa||'—'}</span></div>
          <div class="actions">
            ${o.status==='pendente'?`<button class="btn btn-g" onclick="pubOport(${o.id})">✅ Publicar para especialistas</button>`:''}
            ${o.status==='aberta'?`<button class="btn btn-o" onclick="showTab('candidaturas')">✋ Ver candidaturas</button>`:''}
            <button class="btn btn-r" onclick="updOport(${o.id},'cancelada')">❌ Cancelar</button>
          </div>
        </div>
      </div>`).join('');
  }catch(e){document.getElementById('listaOport').innerHTML='<div class="empty">Erro ao carregar</div>';}
}
function filtO(s,btn){document.querySelectorAll('#page-oportunidades .fb').forEach(b=>b.classList.remove('active'));btn.classList.add('active');loadOport(s);}
async function pubOport(id){
  await fetch('/api/oportunidades',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({id,status:'aberta'})});
  notif('✅ Publicada! Especialistas podem se candidatar.');loadOport('pendente');loadDash();
}
async function updOport(id,status){
  await fetch('/api/oportunidades',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({id,status})});
  notif('Oportunidade atualizada');loadOport();
}

// CANDIDATURAS
async function loadCand(){
  document.getElementById('listaCand').innerHTML='<div class="loading">Carregando...</div>';
  try{
    const data=await fetch('/api/candidaturas').then(r=>r.json());
    const lista=data.candidaturas||[];
    document.getElementById('bCand').textContent=lista.filter(c=>c.status==='pendente').length;
    if(!lista.length){document.getElementById('listaCand').innerHTML='<div class="empty">Nenhuma candidatura ainda</div>';return;}
    document.getElementById('listaCand').innerHTML=lista.map(c=>`
      <div class="card">
        <div class="card-header">
          <div><div class="card-title">${c.prestador_nome}</div><div class="card-sub">${c.prestador_email}</div></div>
          <div style="text-align:right">${bCa(c.status)}<div style="font-size:.75rem;color:var(--muted);margin-top:3px">${c.oportunidade_titulo||'—'}</div></div>
        </div>
        <div class="card-body">
          <div style="display:flex;flex-wrap:wrap;gap:5px;margin-bottom:8px">${pJ(c.especialidades).map(e=>`<span class="badge bb">${e}</span>`).join('')}</div>
          ${c.mensagem?`<div style="font-size:.8rem;color:var(--muted);margin-bottom:9px;padding:9px;background:rgba(46,124,246,.05);border-radius:7px;border-left:2px solid var(--accent)">"${c.mensagem}"</div>`:''}
          <div class="info-row"><span>💰 ${fM(c.valor)}</span><span>🏢 ${c.empresa}</span><span>📅 ${fD(c.created_at)}</span></div>
          ${c.status==='pendente'?`<div class="actions"><button class="btn btn-g" onclick="decidirCand(${c.id},'aprovada')">✅ Escolher este especialista</button><button class="btn btn-r" onclick="decidirCand(${c.id},'reprovada')">❌ Recusar</button></div>`:''}
        </div>
      </div>`).join('');
  }catch(e){document.getElementById('listaCand').innerHTML='<div class="empty">Erro ao carregar</div>';}
}
async function decidirCand(id,status){
  await fetch('/api/candidaturas',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({candidatura_id:id,status})});
  if(status==='aprovada')notif('✅ Especialista escolhido! Projeto criado automaticamente.');
  else notif('Candidatura recusada','var(--yellow)');
  loadCand();loadFin();loadDash();
}

// FINANCEIRO
async function loadFin(){
  try{
    const data=await fetch('/api/admin-financeiro').then(r=>r.json());
    const t=data.totais||{};
    document.getElementById('finStats').innerHTML=`
      <div class="stat-card"><div class="stat-label">Total Bruto</div><div class="stat-value sv-accent">${fM(t.total_bruto)}</div></div>
      <div class="stat-card"><div class="stat-label">Receita Plataforma</div><div class="stat-value sv-green">${fM(t.total_comissao)}</div></div>
      <div class="stat-card"><div class="stat-label">Repasse Especialistas</div><div class="stat-value sv-gold">${fM(t.total_liquido)}</div></div>
      <div class="stat-card"><div class="stat-label">Total Projetos</div><div class="stat-value sv-accent">${t.total_projetos||0}</div></div>`;
    const regs=data.registros||[];
    const tbody=document.getElementById('finBody');
    if(!regs.length){tbody.innerHTML='<tr><td colspan="9" class="empty">Nenhum projeto financeiro ainda</td></tr>';return;}
    tbody.innerHTML=regs.map(r=>`<tr>
      <td><div style="font-weight:500">${r.prestador_nome}</div><div style="font-size:.7rem;color:var(--muted)">${r.prestador_email}</div></td>
      <td>${r.titulo||'—'}</td><td>${r.empresa||'—'}</td>
      <td style="font-weight:600">${fMF(r.valor)}</td>
      <td style="color:var(--accent)">${fMF(r.valor*0.15)}</td>
      <td style="color:var(--green);font-weight:600">${fMF(r.valor*0.85)}</td>
      <td>${r.nf_emitida?'<span class="badge bg">✓</span>':'<span class="badge by">Pendente</span>'}</td>
      <td>${bFi(r.status)}</td>
      <td><select onchange="updFin(${r.id},this.value)" style="background:var(--navy);border:1px solid var(--border);color:var(--white);border-radius:6px;padding:3px 7px;font-size:.73rem">
        <option value="pendente" ${r.status==='pendente'?'selected':''}>Pendente</option>
        <option value="pago" ${r.status==='pago'?'selected':''}>Pago</option>
        <option value="cancelado" ${r.status==='cancelado'?'selected':''}>Cancelado</option>
      </select></td>
    </tr>`).join('');
  }catch(e){console.error(e);}
}
async function updFin(id,status){
  await fetch('/api/admin-financeiro',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({id,status})});
  notif('💰 Financeiro atualizado!');
}

// TICKETS
async function loadTick(status='aberto'){
  document.getElementById('listaTick').innerHTML='<div class="loading">Carregando...</div>';
  try{
    const data=await fetch('/api/tickets').then(r=>r.json());
    const todos=data.tickets||[];
    document.getElementById('bTick').textContent=todos.filter(t=>t.status==='aberto').length;
    const lista=todos.filter(t=>t.status===status);
    if(!lista.length){document.getElementById('listaTick').innerHTML='<div class="empty">Nenhum ticket</div>';return;}
    document.getElementById('listaTick').innerHTML=lista.map(t=>`
      <div class="card" style="cursor:pointer" onclick="abrirTick(${t.id},'${esc(t.assunto)}')">
        <div class="card-header">
          <div><div class="card-title">${t.assunto||'—'}</div><div class="card-sub">${t.prestador_nome} · ${fD(t.created_at)}</div></div>
          ${bTi(t.status)}
        </div>
      </div>`).join('');
  }catch(e){document.getElementById('listaTick').innerHTML='<div class="empty">Erro ao carregar</div>';}
}
function filtT(s,btn){document.querySelectorAll('#page-tickets .fb').forEach(b=>b.classList.remove('active'));btn.classList.add('active');loadTick(s);}
async function abrirTick(id,assunto){
  tickAtual=id;
  document.getElementById('tickTitle').textContent='💬 '+(assunto||'Ticket');
  document.getElementById('tickThread').innerHTML='<div class="loading">Carregando...</div>';
  document.getElementById('moTick').classList.add('open');
  const data=await fetch(`/api/tickets?ticket_id=${id}`).then(r=>r.json());
  const msgs=data.mensagens||[];
  document.getElementById('tickThread').innerHTML=msgs.length===0
    ?'<div class="empty">Sem mensagens</div>'
    :msgs.map(m=>`<div><div class="mb ${m.autor_tipo==='admin'?'admin':'prestador'}">${m.mensagem}<div class="mbt">${m.autor} · ${fD(m.created_at)}</div></div></div>`).join('');
  const el=document.getElementById('tickThread');el.scrollTop=el.scrollHeight;
}
async function respTick(){
  const msg=document.getElementById('tickResp').value.trim();
  if(!msg||!tickAtual)return;
  await fetch('/api/tickets',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({ticket_id:tickAtual,autor:'Admin 123',autor_tipo:'admin',mensagem:msg})});
  document.getElementById('tickResp').value='';
  notif('✅ Resposta enviada!');
  abrirTick(tickAtual,document.getElementById('tickTitle').textContent.replace('💬 ',''));
  loadTick('aberto');loadDash();
}
async function fecharTick(){
  if(!tickAtual)return;
  await fetch('/api/tickets',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify({ticket_id:tickAtual,status:'fechado'})});
  cm('moTick');notif('Ticket fechado');loadTick('aberto');loadDash();
}
</script>
