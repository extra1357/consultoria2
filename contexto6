      <div class="card">
        <table class="table">
          <thead><tr><th>Especialista</th><th>Projeto</th><th>Empresa</th><th>Bruto</th><th>Comissão 15%</th><th>Líquido</th><th>NF</th><th>Status</th><th>Ação</th></tr></thead>
          <tbody id="finBody"><tr><td colspan="9" class="empty">Carregando...</td></tr></tbody>
        </table>
      </div>
