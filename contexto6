    <div class="page" id="page-tickets">
      <div class="page-title">Tickets de Suporte</div>
      <div class="page-sub">Mensagens abertas pelos especialistas</div>
      <div class="filter-row">
        <button class="fb active" onclick="filtT('aberto',this)">🔴 Abertos</button>
        <button class="fb" onclick="filtT('respondido',this)">🟡 Respondidos</button>
        <button class="fb" onclick="filtT('fechado',this)">✅ Fechados</button>
