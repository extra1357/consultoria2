<script>
// ── ESTADO ──────────────────────────────────────────
let tickAtual = null, leadAtual = null, espAtual = null;

// ── AUTH ─────────────────────────────────────────────
function adminLogin() {
  const e = document.getElementById('adminEmail').value;
  const s = document.getElementById('adminSenha').value;
  if (e === 'admin@123consultoria.com.br' && s === 'admin123') {
    localStorage.setItem('adminAuth','1');
    document.getElementById('loginScreen').style.display='none';
    document.getElementById('app').style.display='block';
    initAdmin();
  } else {
    document.getElementById('loginErr').style.display='block';
  }
}
function adminLogout() { localStorage.removeItem('adminAuth'); location.reload(); }
window.onload = () => {
  if (localStorage.getItem('adminAuth')==='1') {
    document.getElementById('loginScreen').style.display='none';
    document.getElementById('app').style.display='block';
    initAdmin();
  }
  document.getElementById('adminSenha').addEventListener('keydown', e => { if(e.key==='Enter') adminLogin(); });
  setInterval(() => {
    document.getElementById('clock').textContent = new Date().toLocaleTimeString('pt-BR');
  }, 1000);
};

function initAdmin() {
  loadDash();
  setInterval(loadDash, 60000);
}

// ── HELPERS ──────────────────────────────────────────
const fM = v => v ? 'R$ '+Number(v).toLocaleString('pt-BR',{minimumFractionDigits:2}) : 'R$ 0,00';
const fD = d => d ? new Date(d).toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit',year:'2-digit',hour:'2-digit',minute:'2-digit'}) : '—';
const pJ = v => { try { return Array.isArray(v)?v:(typeof v==='string'?JSON.parse(v):[]); } catch{ return []; } };
const esc = s => (s||'').replace(/'/g,"\\'");
function cm(id) { document.getElementById(id).classList.remove('open'); }
function notif(msg, bg='var(--accent)') {
  const n = document.getElementById('notif');
  n.textContent = msg; n.style.background = bg; n.style.display='block';
  setTimeout(() => n.style.display='none', 3000);
}
function showTab(t) {
  document.querySelectorAll('.tab').forEach(el=>el.classList.remove('active'));
  document.querySelectorAll('.page').forEach(el=>el.classList.remove('active'));
  event.target.classList.add('active');
  document.getElementById('page-'+t).classList.add('active');
  const loaders = {
    leads: () => loadLeads('novo'),
    especialistas: () => loadEsp('em_analise'),
    oportunidades: () => loadOport('pendente'),
    candidaturas: loadCand,
    financeiro: loadFin,
    tickets: () => loadTick('aberto'),
  };
  if (loaders[t]) loaders[t]();
}

// ── DASHBOARD ────────────────────────────────────────
async function loadDash() {
  try {
    const [lRes, pRes, oRes, cRes, fRes, tRes, audRes] = await Promise.all([
      fetch('/api/leads').then(r=>r.json()),
      fetch('/api/admin-prestadores').then(r=>r.json()),
      fetch('/api/oportunidades?status=aberta').then(r=>r.json()),
      fetch('/api/candidaturas').then(r=>r.json()),
      fetch('/api/admin-financeiro').then(r=>r.json()),
      fetch('/api/tickets').then(r=>r.json()),
      fetch('/api/auditoria').then(r=>r.json()),
    ]);
    const leads = lRes.leads||[];
    const prests = pRes.prestadores||[];
    const oports = oRes.oportunidades||[];
    const cands = cRes.candidaturas||[];
    const ticks = tRes.tickets||[];
    const logs = audRes.logs||[];

    const novos = leads.filter(l=>l.status==='novo').length;
    const ativos = prests.filter(p=>p.status==='ativo').length;
    const pend = prests.filter(p=>p.status==='em_analise').length;
    const candPend = cands.filter(c=>c.status==='pendente').length;
    const tickAbertos = ticks.filter(t=>t.status==='aberto').length;
    const receita = fRes.totais?.total_comissao || 0;

    document.getElementById('dLeads').textContent = novos;
    document.getElementById('dAtivos').textContent = ativos;
    document.getElementById('dPend').textContent = pend;
    document.getElementById('dOport').textContent = oports.length;
    document.getElementById('dCand').textContent = candPend;
    document.getElementById('dReceita').textContent = fM(receita);
    document.getElementById('dTick').textContent = tickAbertos;

    document.getElementById('bLeads').textContent = novos;
    document.getElementById('bPend').textContent = pend;
    document.getElementById('bOport').textContent = oports.length;
    document.getElementById('bCand').textContent = candPend;
    document.getElementById('bTick').textContent = tickAbertos;

    // Auditoria recente
    document.getElementById('dashAud').innerHTML = logs.slice(0,5).map(l=>`
      <div class="card" style="margin-bottom:6px">
        <div style="padding:10px 14px;font-size:.78rem">
          <span style="color:var(--accent)">${l.evento}</span>
          <span style="color:var(--muted);margin-left:8px">${fD(l.created_at)}</span>
          <div style="color:var(--muted);margin-top:2px;font-size:.73rem">${l.detalhes||''}</div>
        </div>
      </div>`).join('') || '<div class="empty">Sem ações recentes</div>';

    // Leads recentes
    document.getElementById('dashLeads').innerHTML = leads.slice(0,4).map(l=>`
      <div class="card" style="margin-bottom:6px;cursor:pointer" onclick="abrirLead(${l.id})">
        <div style="padding:10px 14px;font-size:.78rem;display:flex;justify-content:space-between;align-items:center">
          <div>
            <div style="font-weight:600">${l.nome}</div>
            <div style="color:var(--muted);font-size:.72rem">${l.empresa} · ${l.servico||'—'}</div>
          </div>
          ${bLe(l.status)}
        </div>
      </div>`).join('') || '<div class="empty">Nenhum lead</div>';

  } catch(e) { console.error('Dash erro:', e); }
}

// ── BADGE HELPERS ────────────────────────────────────
function bLe(s) {
  const m = {novo:'bb 🔵 Novo',em_contato:'by 📞 Em contato',convertido:'bg ✅ Convertido',descartado:'br ❌ Descartado'};
  const c = m[s]||'bgr '+s; const [cls,...rest]=c.split(' ');
  return `<span class="badge ${cls}">${rest.join(' ')}</span>`;
}
function bPr(s) {
  const m = {ativo:'bg ✅ Ativo',em_analise:'by ⏳ Análise',reprovado:'br ❌ Reprovado',inativo:'bgr Inativo'};
  const c = m[s]||'bgr '+s; const [cls,...rest]=c.split(' ');
  return `<span class="badge ${cls}">${rest.join(' ')}</span>`;
}
function bOp(s) {
  const m = {pendente:'by ⏳ Pendente',aberta:'bg ✅ Aberta',em_andamento:'bb 🔄 Andamento',concluida:'bgo 🏁 Concluída'};
  const c = m[s]||'bgr '+s; const [cls,...rest]=c.split(' ');
  return `<span class="badge ${cls}">${rest.join(' ')}</span>`;
}
function bCa(s) {
  const m = {pendente:'by ⏳ Pendente',aprovada:'bg ✅ Aprovada',reprovada:'br ❌ Reprovada'};
  const c = m[s]||'bgr '+s; const [cls,...rest]=c.split(' ');
  return `<span class="badge ${cls}">${rest.join(' ')}</span>`;
}
function bFi(s) {
  const m = {pendente:'by ⏳ Pendente',pago:'bg ✅ Pago',cancelado:'br ❌ Cancelado'};
