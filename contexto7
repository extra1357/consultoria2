.stat-card{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:16px 18px}
.stat-label{font-size:.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;margin-bottom:6px}
.stat-value{font-size:1.5rem;font-weight:700;font-family:'Cormorant Garamond',serif}
.sv-green{color:var(--green)}.sv-accent{color:var(--accent)}.sv-gold{color:var(--gold)}.sv-yellow{color:var(--yellow)}.sv-red{color:var(--red)}
.card{background:var(--card);border:1px solid var(--border);border-radius:14px;margin-bottom:10px;overflow:hidden}
.card-header{padding:14px 18px;display:flex;align-items:center;justify-content:space-between;gap:12px}
.card-body{padding:0 18px 14px}
.card-title{font-weight:600;font-size:.88rem}
.card-sub{font-size:.75rem;color:var(--muted);margin-top:2px}
.badge{padding:3px 9px;border-radius:20px;font-size:.7rem;font-weight:600;white-space:nowrap;display:inline-block}
.bg{background:rgba(34,197,94,.15);color:var(--green)}
.by{background:rgba(245,158,11,.15);color:var(--yellow)}
.bb{background:rgba(46,124,246,.15);color:var(--accent)}
.br{background:rgba(239,68,68,.15);color:var(--red)}
.bgr{background:rgba(107,130,168,.15);color:var(--muted)}
.bgo{background:rgba(201,168,76,.15);color:var(--gold)}
.actions{display:flex;gap:7px;flex-wrap:wrap;margin-top:11px}
.btn{padding:6px 13px;border-radius:8px;font-size:.76rem;font-weight:600;cursor:pointer;border:none;font-family:'Outfit',sans-serif;transition:.2s}
.btn-g{background:rgba(34,197,94,.15);color:var(--green);border:1px solid rgba(34,197,94,.2)}.btn-g:hover{background:rgba(34,197,94,.3)}
.btn-r{background:rgba(239,68,68,.15);color:var(--red);border:1px solid rgba(239,68,68,.2)}.btn-r:hover{background:rgba(239,68,68,.3)}
.btn-a{background:var(--accent);color:#fff;border:1px solid var(--accent)}.btn-a:hover{background:var(--accent2)}
.btn-o{background:transparent;border:1px solid var(--border);color:var(--muted)}.btn-o:hover{border-color:var(--accent);color:var(--accent)}
.btn-y{background:rgba(245,158,11,.15);color:var(--yellow);border:1px solid rgba(245,158,11,.2)}.btn-y:hover{background:rgba(245,158,11,.3)}
.filter-row{display:flex;gap:7px;margin-bottom:14px;flex-wrap:wrap}
.fb{padding:6px 13px;border-radius:20px;font-size:.76rem;font-weight:500;cursor:pointer;border:1px solid var(--border);background:transparent;color:var(--muted);font-family:'Outfit',sans-serif;transition:.2s}
.fb:hover,.fb.active{border-color:var(--accent);color:var(--accent);background:rgba(46,124,246,.08)}
.empty{text-align:center;padding:36px;color:var(--muted);font-size:.85rem}
.loading{text-align:center;padding:28px;color:var(--muted);font-size:.83rem}
.table-wrap{overflow-x:auto}
.table{width:100%;border-collapse:collapse}
.table th{text-align:left;font-size:.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;padding:9px 12px;border-bottom:1px solid var(--border)}
.table td{padding:11px 12px;border-bottom:1px solid rgba(46,124,246,.06);font-size:.82rem;vertical-align:middle}
.mo{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:500;display:none;align-items:center;justify-content:center;padding:20px}
.mo.open{display:flex}
.modal{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:26px;width:100%;max-width:520px;max-height:88vh;overflow-y:auto}
.modal-title{font-size:.95rem;font-weight:600;margin-bottom:16px;display:flex;align-items:center;justify-content:space-between}
.mc{background:none;border:none;color:var(--muted);cursor:pointer;font-size:1.1rem}
.field{margin-bottom:12px}
.field label{font-size:.72rem;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;display:block;margin-bottom:4px}
.field input,.field textarea,.field select{width:100%;background:rgba(6,15,30,.8);border:1px solid var(--border);border-radius:8px;padding:9px 11px;color:var(--white);font-family:'Outfit',sans-serif;font-size:.86rem;outline:none}
.field textarea{resize:vertical;min-height:80px}
.thread{display:flex;flex-direction:column;gap:9px;max-height:260px;overflow-y:auto;margin-bottom:12px;padding:4px}
.mb{padding:9px 13px;border-radius:10px;font-size:.82rem;line-height:1.5;max-width:84%}
.mb.admin{background:var(--accent);align-self:flex-end;border-radius:10px 2px 10px 10px}
.mb.prestador{background:rgba(46,124,246,.1);border:1px solid var(--border);align-self:flex-start;border-radius:2px 10px 10px 10px}
.mbt{font-size:.65rem;color:rgba(255,255,255,.45);margin-top:3px}
.notif{position:fixed;top:66px;right:20px;padding:11px 18px;border-radius:10px;font-size:.83rem;font-weight:600;z-index:999;display:none;animation:sli .3s ease}
@keyframes sli{from{transform:translateX(110%)}to{transform:translateX(0)}}
.info-row{display:flex;gap:16px;flex-wrap:wrap;font-size:.78rem;color:var(--muted);margin-top:8px}
.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px}
.detail-item{background:rgba(6,15,30,.5);border-radius:8px;padding:9px 12px}
.detail-label{font-size:.68rem;color:var(--muted);text-transform:uppercase;margin-bottom:3px}
.detail-value{font-size:.84rem;color:var(--white)}
.lbtn{background:transparent;border:1px solid var(--border);color:var(--muted);padding:6px 13px;border-radius:8px;font-size:.78rem;cursor:pointer;font-family:'Outfit',sans-serif}
.lbtn:hover{border-color:var(--red);color:var(--red)}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:16px}
@media(max-width:700px){.two-col{grid-template-columns:1fr}.detail-grid{grid-template-columns:1fr}}
</style>
</head>
