<script>
let _leads=[], _negs=[], _esps=[], _projs=[];
let leadAtual=null, negAtual=null, espAtual=null, projAtual=null;

// AUTH
function adminLogin(){
  const s=document.getElementById('adminSenha').value;
  if(s==='123admin'){
    localStorage.setItem('adminAuth','1');
    document.getElementById('loginScreen').style.display='none';
    document.getElementById('app').style.display='block';
    init();
  } else {
    document.getElementById('loginErr').style.display='block';
  }
}
function adminLogout(){ localStorage.removeItem('adminAuth'); location.reload(); }
window.onload=()=>{
  if(localStorage.getItem('adminAuth')==='1'){
    document.getElementById('loginScreen').style.display='none';
    document.getElementById('app').style.display='block';
    init();
  }
  document.getElementById('adminSenha').addEventListener('keydown',e=>{if(e.key==='Enter')adminLogin();});
  setInterval(()=>{ document.getElementById('clock').textContent=new Date().toLocaleTimeString('pt-BR'); },1000);
};
function init(){ loadDash(); setInterval(loadDash,60000); }

// HELPERS
const fM=v=>v?'R$ '+Number(v).toLocaleString('pt-BR',{minimumFractionDigits:2,maximumFractionDigits:2}):'R$ 0,00';
const fD=d=>d?new Date(d).toLocaleDateString('pt-BR',{day:'2-digit',month:'2-digit',year:'2-digit',hour:'2-digit',minute:'2-digit'}):'—';
const pJ=v=>{try{return Array.isArray(v)?v:(typeof v==='string'?JSON.parse(v):[]);}catch{return[];}};
const esc=s=>(s||'').replace(/'/g,"\\'").replace(/"/g,'&quot;');
function cm(id){document.getElementById(id).classList.remove('open');}
function notif(msg,bg='var(--accent)'){
  const n=document.getElementById('notif');
  n.textContent=msg;n.style.background=bg;n.style.display='block';
  setTimeout(()=>n.style.display='none',3500);
}
function showTab(t,el){
  document.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));
  document.querySelectorAll('.page').forEach(x=>x.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('page-'+t).classList.add('active');
  const m={leads:()=>loadLeads('novo'),negociacoes:()=>loadNegs('aguardando_validacao'),
    especialistas:()=>loadEsps('em_analise'),projetos:()=>loadProjs('em_andamento'),
    financeiro:loadFin,auditoria_log:loadAudLog};
  if(m[t])m[t]();
}

// BADGES
function bLe(s){const m={novo:'bb 🔵 Novo',em_negociacao:'by 🤝 Negociação',convertido:'bg ✅ Convertido',descartado:'br ❌ Descartado'};const c=m[s]||'bgr '+s;const[cl,...r]=c.split(' ');return`<span class="badge ${cl}">${r.join(' ')}</span>`;}
function bNe(s){const m={aguardando_validacao:'by ⏳ Aguardando',aprovada:'bg ✅ Aprovada',revisao:'bb 🔄 Revisão'};const c=m[s]||'bgr '+s;const[cl,...r]=c.split(' ');return`<span class="badge ${cl}">${r.join(' ')}</span>`;}
function bPr(s){const m={ativo:'bg ✅ Ativo',em_analise:'by ⏳ Análise',reprovado:'br ❌ Reprovado'};const c=m[s]||'bgr '+s;const[cl,...r]=c.split(' ');return`<span class="badge ${cl}">${r.join(' ')}</span>`;}
function bPj(s){const m={em_andamento:'bb 🔄 Andamento',concluido:'bg ✅ Concluído',pausado:'by ⏸ Pausado'};const c=m[s]||'bgr '+s;const[cl,...r]=c.split(' ');return`<span class="badge ${cl}">${r.join(' ')}</span>`;}
function bFi(s){const m={pendente:'by ⏳ Pendente',pago:'bg ✅ Pago',cancelado:'br ❌ Cancelado'};const c=m[s]||'bgr '+s;const[cl,...r]=c.split(' ');return`<span class="badge ${cl}">${r.join(' ')}</span>`;}

// DASHBOARD
async function loadDash(){
  try{
    const[lR,nR,pR,fR,eR,aR]=await Promise.all([
      fetch('/api/leads').then(r=>r.json()),
      fetch('/api/negociacoes').then(r=>r.json()),
      fetch('/api/projetos').then(r=>r.json()),
      fetch('/api/admin-financeiro').then(r=>r.json()),
      fetch('/api/admin-prestadores').then(r=>r.json()),
      fetch('/api/auditoria').then(r=>r.json()),
    ]);
    const leads=lR.leads||[], negs=nR.negociacoes||[], projs=pR.projetos||[];
    const esps=eR.prestadores||[], fin=fR.totais||{};

    const novos=leads.filter(l=>l.status==='novo').length;
    const emNeg=leads.filter(l=>l.status==='em_negociacao').length;
    const val=negs.filter(n=>n.status==='aguardando_validacao').length;
    const ativos=projs.filter(p=>p.status==='em_andamento').length;
    const espAtivos=esps.filter(e=>e.status==='ativo').length;
    const pend=esps.filter(e=>e.status==='em_analise').length;

    document.getElementById('dLeads').textContent=novos;
    document.getElementById('dNegs').textContent=emNeg;
    document.getElementById('dVal').textContent=val;
    document.getElementById('dProj').textContent=ativos;
    document.getElementById('dRec').textContent=fM(fin.total_bruto);
    document.getElementById('dCom').textContent=fM(fin.total_comissao);
    document.getElementById('dEsp').textContent=espAtivos;
    document.getElementById('dPend').textContent=pend;

    document.getElementById('bLeads').textContent=novos;
    document.getElementById('bNegs').textContent=val;
    document.getElementById('bPend').textContent=pend;
    document.getElementById('bProj').textContent=ativos;

    // Propostas para validar
    const pendNegs=negs.filter(n=>n.status==='aguardando_validacao').slice(0,4);
    document.getElementById('dashNegs').innerHTML=pendNegs.length
      ?pendNegs.map(n=>`
        <div class="card" style="cursor:pointer;margin-bottom:8px" onclick="abrirNeg(${n.id})">
          <div style="padding:11px 16px">
            <div style="font-weight:600;font-size:.85rem">${n.lead_nome} — ${n.lead_empresa}</div>
            <div style="font-size:.76rem;color:var(--muted)">${n.especialista_nome} · ${fD(n.created_at)}</div>
            <div style="font-size:.88rem;color:var(--green);font-weight:600;margin-top:4px">${fM(n.valor_proposto)} · ${n.prazo_proposto||'—'}</div>
          </div>
        </div>`).join('')
      :'<div class="empty">Nenhuma proposta pendente</div>';

    // Projetos ativos
    const projAtivos=projs.filter(p=>p.status==='em_andamento').slice(0,4);
    document.getElementById('dashProjs').innerHTML=projAtivos.length
      ?projAtivos.map(p=>`
        <div class="card" style="margin-bottom:8px;cursor:pointer" onclick="abrirProj(${p.id})">
          <div style="padding:11px 16px">
            <div style="font-weight:600;font-size:.85rem">${p.titulo||p.empresa}</div>
            <div style="font-size:.76rem;color:var(--muted)">${p.especialista_nome} · ${fM(p.valor)}</div>
            <div class="prog-bar"><div class="prog-fill" style="width:${p.progresso||0}%"></div></div>
            <div style="font-size:.72rem;color:var(--muted);margin-top:3px">${p.progresso||0}% concluído</div>
          </div>
        </div>`).join('')
      :'<div class="empty">Nenhum projeto ativo</div>';

  }catch(e){console.error(e);}
}

// LEADS
async function loadLeads(status='novo'){
  document.getElementById('listaLeads').innerHTML='<div class="loading">Carregando...</div>';
  try{
    const url=status?`/api/leads?status=${status}`:'/api/leads';
    const data=await fetch(url).then(r=>r.json());
    _leads=data.leads||[];
    document.getElementById('bLeads').textContent=_leads.filter(l=>l.status==='novo').length;
    if(!_leads.length){document.getElementById('listaLeads').innerHTML='<div class="empty">Nenhum lead neste status</div>';return;}
    document.getElementById('listaLeads').innerHTML=_leads.map(l=>`
      <div class="card" style="cursor:pointer" onclick="abrirLead(${l.id})">
        <div class="card-header">
          <div>
            <div class="card-title">${l.nome}</div>
            <div class="card-sub">${l.empresa} · ${l.email} · ${l.whatsapp}</div>
            ${l.especialista_nome_ref?`<div style="font-size:.74rem;color:var(--accent);margin-top:3px">👤 ${l.especialista_nome_ref}</div>`:'<div style="font-size:.74px;color:var(--red);margin-top:3px">⚠ Sem especialista</div>'}
          </div>
          <div style="text-align:right;flex-shrink:0">
            ${bLe(l.status)}
            <div style="font-size:.72rem;color:var(--muted);margin-top:4px">${fD(l.criado_em)}</div>
          </div>
        </div>
        <div class="card-body">
          <div style="font-size:.8rem;color:var(--accent);font-weight:500">${l.servico||'—'}</div>
          ${l.mensagem?`<div style="font-size:.78rem;color:var(--muted);margin-top:5px;padding:7px;background:rgba(46,124,246,.05);border-radius:6px;border-left:2px solid var(--accent)">"${l.mensagem}"</div>`:''}
          ${l.notas?`<div style="font-size:.74rem;color:var(--yellow);margin-top:5px">📝 ${l.notas}</div>`:''}
          <div class="actions">
            <button class="btn btn-a" onclick="event.stopPropagation();abrirLead(${l.id})">✏️ Gerenciar</button>
            <button class="btn btn-g" onclick="event.stopPropagation();wa('${l.whatsapp}','${esc(l.nome)}')">💬 WhatsApp</button>
          </div>
        </div>
      </div>`).join('');
  }catch(e){document.getElementById('listaLeads').innerHTML='<div class="empty">Erro ao carregar</div>';}
}
function filtL(s,btn){document.querySelectorAll('#page-leads .fb').forEach(b=>b.classList.remove('active'));btn.classList.add('active');loadLeads(s);}

async function abrirLead(id){
  const l=_leads.find(x=>x.id===id);if(!l)return;
  leadAtual=l;
  document.getElementById('leadTitle').textContent='📋 '+l.nome;
  document.getElementById('leadStatus').value=l.status||'novo';
  document.getElementById('leadNotas').value=l.notas||'';
  document.getElementById('leadDetail').innerHTML=`
    <div class="dg">
      <div class="di"><div class="dl">Empresa</div><div class="dv">${l.empresa||'—'}</div></div>
      <div class="di"><div class="dl">Serviço</div><div class="dv">${l.servico||'—'}</div></div>
      <div class="di"><div class="dl">E-mail</div><div class="dv">${l.email||'—'}</div></div>
      <div class="di"><div class="dl">WhatsApp</div><div class="dv">${l.whatsapp||'—'}</div></div>
      <div class="di" style="grid-column:1/-1"><div class="dl">Mensagem</div><div class="dv" style="white-space:pre-wrap">${l.mensagem||'—'}</div></div>
      <div class="di"><div class="dl">Recebido</div><div class="dv">${fD(l.criado_em)}</div></div>
      <div class="di"><div class="dl">Especialista atual</div><div class="dv">${l.especialista_nome_ref||'Não atribuído'}</div></div>
    </div>`;
  // Carrega especialistas ativos para o select
  const eData=await fetch('/api/admin-prestadores?status=ativo').then(r=>r.json());
  const esps=eData.prestadores||[];
  const sel=document.getElementById('leadEsp');
  sel.innerHTML='<option value="">— Manter atual —</option>'+esps.map(e=>`<option value="${e.id}" ${e.id==l.especialista_id?'selected':''}>${e.nome}</option>`).join('');
  document.getElementById('moLead').classList.add('open');
}
async function salvarLead(){
  if(!leadAtual)return;
  const status=document.getElementById('leadStatus').value;
  const notas=document.getElementById('leadNotas').value;
  const esp=document.getElementById('leadEsp').value;
  const body={id:leadAtual.id,status,notas};
  if(esp)body.especialista_id=parseInt(esp);
  await fetch('/api/leads',{method:'PATCH',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
  notif('✅ Lead atualizado!');cm('moLead');
  loadLeads(document.querySelector('#page-leads .fb.active')?document.querySelector('#page-leads .fb.active').textContent.trim():'');
  loadDash();
}
function wa(tel,nome){const n=(tel||'').replace(/\D/g,'');const m=encodeURIComponent(`Olá ${nome}, sou da equipe 123 Consultoria!`);window.open(`https://wa.me/55${n}?text=${m}`,'_blank');}
function waLead(){if(leadAtual)wa(leadAtual.whatsapp,leadAtual.nome);}

// NEGOCIAÇÕES
async function loadNegs(status='aguardando_validacao'){
  document.getElementById('listaNegs').innerHTML='<div class="loading">Carregando...</div>';
  try{
    const data=await fetch('/api/negociacoes').then(r=>r.json());
    _negs=data.negociacoes||[];
    const filtrados=status?_negs.filter(n=>n.status===status):_negs;
    document.getElementById('bNegs').textContent=_negs.filter(n=>n.status==='aguardando_validacao').length;
    if(!filtrados.length){document.getElementById('listaNegs').innerHTML='<div class="empty">Nenhuma negociação neste status</div>';return;}
    document.getElementById('listaNegs').innerHTML=filtrados.map(n=>`
      <div class="card" style="cursor:pointer" onclick="abrirNeg(${n.id})">
        <div class="card-header">
          <div>
            <div class="card-title">${n.lead_nome} — ${n.lead_empresa}</div>
            <div class="card-sub">Especialista: ${n.especialista_nome} · ${fD(n.created_at)}</div>
          </div>
          <div style="text-align:right;flex-shrink:0">
            ${bNe(n.status)}
            <div style="font-size:.82rem;color:var(--green);font-weight:600;margin-top:4px">${fM(n.valor_proposto)}</div>
          </div>
        </div>
        <div class="card-body">
          <div class="info-row">
            <span>⏱ Prazo: ${n.prazo_proposto||'—'}</span>
            <span>📅 Reunião: ${fD(n.data_reuniao)}</span>
