Na verdade o sed multilinha é complicado. Vamos fazer direto com Python que é mais seguro:
bash

cd ~/consultoria2
python3 << 'EOF'
with open('index.html', 'r') as f:
    html = f.read()

replacements = [
    ('Consultoria Empresarial', '/servicos/consultoria-empresarial.html'),
    ('Planejamento Financeiro', '/servicos/planejamento-financeiro.html'),
    ('RH & Pessoas',            '/servicos/rh-pessoas.html'),
    ('Compliance & Governança', '/servicos/compliance-governanca.html'),
    ('Marketing Digital',       '/servicos/marketing-digital.html'),
    ('Fusões & Aquisições',     '/servicos/fusoes-aquisicoes.html'),
    ('Gestão Estratégica',      '/servicos/gestao-estrategica.html'),
]

import re
for titulo, url in replacements:
    pattern = r'(<div class="servico-titulo">' + re.escape(titulo) + r'</div>.*?)<div class="servico-link">Saiba mais →</div>'
    replacement = r'\1<a href="' + url + r'" class="servico-link">Saiba mais →</a>'
    html = re.sub(pattern, replacement, html, flags=re.DOTALL)

with open('index.html', 'w') as f:
    f.write(html)

print("✅ Links atualizados!")
EOF

